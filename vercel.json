{
  "version": 2,
  "buildCommand": "cd web && npm run build",
  "outputDirectory": "web/dist",
  "env": {
    "PYTHONPATH": "/vercel/path0:/vercel/path0/api"
  },
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@3.12",
      "maxDuration": 60,
      "memory": 2048,
      "includeFiles": "engine/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "web/$1"
    }
  ]
}
